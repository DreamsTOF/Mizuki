        <!-- 业务组件 -->
        <sa-token.version>1.40.0</sa-token.version>
        <redisson.version>3.50.0</redisson.version>
        <cos-api.version>5.6.227</cos-api.version>

        <!-- [NEW] 工具库 (替代 Hutool) -->
        <uuid-create.version>6.1.1</uuid-create.version>
        <commons-lang3.version>3.14.0</commons-lang3.version>
        <commons-collections4.version>4.4</commons-collections4.version>
        <commons-codec.version>1.16.1</commons-codec.version>
        <commons-io.version>2.15.1</commons-io.version>
        <commons-pool2.version>2.12.0</commons-pool2.version>
        <guava.version>33.0.0-jre</guava.version>
        <okhttp.version>5.3.2</okhttp.version>
        <easyexcel.version>3.3.4</easyexcel.version>
        <caffeine.version>3.1.8</caffeine.version>
        <mapstruct.version>1.6.3</mapstruct.version>
        <jackson.version>2.18.2</jackson.version>
        <eclipse-collections.version>13.0.0</eclipse-collections.version>
        <zero-allocation-hashing.version>0.16</zero-allocation-hashing.version>
        <javers-core.version>7.11.0</javers-core.version>
        <playwright.version>1.59.0</playwright.version>
        <bcpkey.version>1.84</bcpkey.version>

        <!-- 开发辅助 -->
        <lombok.version>1.18.42</lombok.version>
        <knife4j.version>4.5.0</knife4j.version>
        <springdoc-openapi.version>2.8.16</springdoc-openapi.version>
        <swagger.annotations.version>2.2.20</swagger.annotations.version>
        <chronicle-map.version>2026.1</chronicle-map.version>
        <rocksdbjni.version>10.10.1</rocksdbjni.version>
        <argon2-jvm.version>2.12</argon2-jvm.version>

    </properties>

    <!-- 全局通用依赖 (所有子模块都会自动引入) -->
    <dependencies>
        <!-- Lombok: 几乎所有模块都需要，提上来减少重复 -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <version>${lombok.version}</version>
            <scope>provided</scope>
        </dependency>

        <!-- MapStruct 核心库 (配合插件使用，子模块无需再引) -->
        <dependency>
            <groupId>org.mapstruct</groupId>
            <artifactId>mapstruct</artifactId>
            <version>${mapstruct.version}</version>
        </dependency>

        <!-- 常用工具库 (Lang3, Collections) -->
        <dependency>
            <groupId>org.apache.commons</groupId>
            <artifactId>commons-lang3</artifactId>
        </dependency>
        <dependency>
            <groupId>org.apache.commons</groupId>
            <artifactId>commons-collections4</artifactId>
        </dependency>

        <!-- Jackson 注解 (常用与 DTO/POJO) -->
        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-annotations</artifactId>
        </dependency>

    </dependencies>

