    <groupId>cn.dreamtof</groupId>
    <artifactId>blog</artifactId>
    <version>0.0.1-SNAPSHOT</version>
    <name>fans-songs</name>
    <description>fans-songs 聚合父工程</description>
    <packaging>pom</packaging>

    <modules>
        <module>dreamtof-log</module>
        <module>dreamtof-blog</module>
        <module>dreamtof-query</module>
        <module>dreamtof-core</module>
        <module>dreamtof-audit</module>
