{
  "name": "songs-frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "fresh": "rm -rf node_modules pnpm-lock.yaml && pnpm install",
    "dev": "vite --force",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "openapi2ts": "openapi2ts",
    "lint": "run-s lint:*",
    "lint:oxlint": "oxlint . --fix",
    "lint:eslint": "eslint . --fix --cache",
    "format": "oxfmt src/",
    "api:gen": "node src/scripts/fix-api-json.js && orval && node src/scripts/merge-models.js && node src/scripts/gen-api.js && node src/scripts/gen-services.js",
    "api:gen:url": "node src/scripts/download-api.js && node src/scripts/fix-api-json.js && orval && node src/scripts/merge-models.js && node src/scripts/gen-api.js && node src/scripts/gen-services.js",
    "api:gen:url:dev": "API_DOWNLOAD_URL=http://127.0.0.1:4523/export/openapi/2?version=openapi30 pnpm api:gen:url"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@fingerprintjs/fingerprintjs": "^5.2.0",
    "@formkit/auto-animate": "^0.9.0",
    "@sentry/vue": "^10.49.0",
    "@tanstack/vue-query": "^5.99.2",
    "@tanstack/vue-table": "^8.21.3",
    "@vee-validate/zod": "^4.15.1",
    "@vueuse/core": "^14.2.1",
    "axios": "^1.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "libsodium-wrappers": "^0.7.15",
    "mlkem": "^2.2.0",
    "lucide-vue-next": "^1.0.0",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "playwright": "^1.59.1",
    "reka-ui": "^2.9.6",
    "shadcn-vue": "^2.6.2",
    "tailwind-merge": "^3.5.0",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@umijs/openapi": "^1.14.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.57.0",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "npm-run-all2": "^8.0.4",
    "openapi-typescript": "^7.13.0",
    "orval": "^8.6.2",
    "oxfmt": "^0.42.0",
    "oxlint": "~1.57.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "terser": "^5.46.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.0",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.3",
    "vite-plugin-vue-devtools": "^8.1.1",
    "vue-tsc": "^3.2.6"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
